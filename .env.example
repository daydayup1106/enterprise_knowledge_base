# ==================================================
# Enterprise Knowledge Base - Configuration Template
# Copy this to .env and fill in your actual values.
# DO NOT commit .env to git.
# ==================================================

# ---- DeepSeek API ----
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ---- Local Model Paths (absolute paths to downloaded weights) ----
# Download commands:
#   python -c "from huggingface_hub import snapshot_download; snapshot_download('BAAI/bge-small-zh-v1.5', local_dir='D:/models/bge-small-zh-v1.5')"
#   python -c "from huggingface_hub import snapshot_download; snapshot_download('BAAI/bge-reranker-base', local_dir='D:/models/bge-reranker-base')"
EMBED_MODEL_NAME=D:/models/bge-small-zh-v1.5
RERANK_MODEL_NAME=D:/models/bge-reranker-base
# "cuda" = GPU 0, "cuda:1" = GPU 1, "cpu" = no GPU
DEVICE=cuda

# ---- RAG Pipeline ----
RAG_HYBRID_TOP_K=10
RAG_RERANK_TOP_N=3
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# ---- LangGraph Memory ----
MEMORY_WINDOW=10

# ---- Redis State Persistence ----
REDIS_URL=redis://localhost:6379/0

# ---- Knowledge Base Doc Path (relative to project root) ----
KNOWLEDGE_BASE_DOC=data/medical_ai_papers_2024_2025.md
